{
  "name": "depth-scanner-lab",
  "version": "1.1.0-beta",
  "description": "Depth Scanner OSS — AI depth map generator",
  "main": "main.js",
  "scripts": {
    "start": "unset ELECTRON_RUN_AS_NODE && electron .",
    "dev": "unset ELECTRON_RUN_AS_NODE && electron . --dev",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.depthscanner.oss",
    "productName": "Depth Scanner Lab",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "setup.js",
      "preload.js",
      "ui/**/*",
      "icons/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": ["**/*", "!.venv/**", "!__pycache__/**", "!*.pyc"]
      }
    ],
    "mac": {
      "category": "public.app-category.video",
      "icon": "icons/icon.png",
      "target": ["dmg"]
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage"]
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0"
  }
}
