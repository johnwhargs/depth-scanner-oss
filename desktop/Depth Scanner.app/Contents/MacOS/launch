#!/bin/bash
# Depth Scanner OSS — macOS App Launcher
DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
VENV="$DIR/../backend/.venv/bin/activate"

if [ ! -f "$VENV" ]; then
    osascript -e 'display alert "Depth Scanner" message "Backend not set up. Run:\n\ncd backend && python3 -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt" as warning'
    exit 1
fi

source "$VENV"
cd "$DIR"
exec python app.py
